@model IReadOnlyList<ReallyCoolPrd.Web.Models.TodoItem>
@{
    ViewData["Title"] = "Heatwave Todos";
}

<div class="heatwave-card p-4 p-md-5">
    <h1 class="display-6 mb-3">Heatwave Todos</h1>
    <p class="text-body-secondary mb-4">Keep your tasks blazing forward.</p>

    <form asp-action="Add" method="post" class="row g-2 mb-4">
        <div class="col-sm-9">
            <input class="form-control form-control-lg" name="title" placeholder="Add a new task" maxlength="120" />
        </div>
        <div class="col-sm-3 d-grid">
            <button class="btn btn-heatwave btn-lg" type="submit">Add</button>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <p class="mb-0">No tasks yet — add your first one.</p>
    }
    else
    {
        <ul class="list-group list-group-flush">
            @foreach (var item in Model)
            {
                <li class="list-group-item d-flex align-items-center justify-content-between px-0 bg-transparent border-0 border-bottom border-opacity-25 py-3">
                    <div class="@(item.IsDone ? "todo-done" : string.Empty)">@item.Title</div>
                    <div class="d-flex gap-2">
                        <form asp-action="Toggle" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-heatwave">@(item.IsDone ? "Undo" : "Done")</button>
                        </form>
                        <form asp-action="Delete" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </div>
                </li>
            }
        </ul>
    }
</div>
